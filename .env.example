# ============================================================
# Norte — Variables de entorno
# Copiá este archivo a `.env` y completá los valores.
# En el VPS: editá el .env y corré `docker compose up -d --build`.
# ============================================================

# --- App ---
# URL pública de la app (en el VPS: https://tudominio.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Base de datos (Postgres del docker-compose) ---
POSTGRES_USER=norte
POSTGRES_PASSWORD=cambiame_en_produccion
POSTGRES_DB=norte
# "db" es el nombre del servicio en docker-compose (no usar localhost dentro de Docker)
DATABASE_URL=postgresql://norte:cambiame_en_produccion@db:5432/norte

# --- Clerk (autenticación) ---
# Las genera `clerk init` / el dashboard de Clerk (pk_test/sk_test en dev,
# pk_live/sk_live en producción).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Binance (fase 3) ---
# true  -> usa el Spot Testnet (https://testnet.binance.vision), fondos de prueba
# false -> API real de Binance (solo cuando esté todo testeado)
BINANCE_USE_TESTNET=true

# --- Seguridad ---
# Clave para cifrar las API keys de Binance en la base de datos.
# Generala con:  openssl rand -hex 32
ENCRYPTION_KEY=

# --- Robot de trading ---
# Secreto que autentica al scheduler contra /api/bot/tick.
# Generalo con:  openssl rand -hex 24
CRON_SECRET=
# Cada cuántos segundos el scheduler dispara un tick del robot.
BOT_TICK_SECONDS=60
# ¡PELIGRO! Solo poner en true cuando TODO esté validado en el testnet y
# quieras operar con dinero real (junto con BINANCE_USE_TESTNET=false).
# ALLOW_REAL_TRADING=true

# --- Administración ---
# Emails (de cuentas Clerk verificadas) con acceso al panel /admin, separados por coma.
ADMIN_EMAILS=

# --- MercadoPago (facturación) ---
# Access token de la aplicación (panel de desarrolladores de MercadoPago).
# Para probar sin cobrar de verdad, usar las credenciales de PRUEBA.
MP_ACCESS_TOKEN=
# Secreto de firma de webhooks (se genera al configurar el webhook en MP,
# apuntando a https://tudominio.com/api/mp/webhook).
MP_WEBHOOK_SECRET=
# Solo para QA en sandbox: email de una cuenta de prueba compradora de MP.
# Pisa el email real del usuario como pagador. DEJAR VACÍO en producción.
MP_TEST_PAYER_EMAIL=

# --- Servidor ---
# IP de salida del VPS donde corre el robot. Se muestra en la guía de
# conexión de Binance (todos los usuarios restringen su API key a esta IP).
SERVER_IP=72.62.170.218
